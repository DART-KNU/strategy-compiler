{
  "version": "1.0",
  "strategy_id": "contest_gradual",
  "strategy_name": "Contest Gradual (월간 신호 + 주간 5% 실행)",
  "mode": "contest",
  "description": "대회용 이중 주기 전략. 신호: 월말 팩터 계산. 실행: 매주 최대 5% 회전율로 타겟을 향해 점진적 접근. 주간 5% 최소 회전율 규정 준수 + 거래비용 최소화.",
  "objective": "maximize_return",
  "date_range": {
    "start": "2023-03-18",
    "end": "2026-03-20"
  },
  "base_universe": {
    "base": "is_eligible",
    "markets": ["코스피", "코스닥"],
    "include_blocked": false
  },
  "benchmark": {
    "index_code": "KOSPI200",
    "proxy_type": "return_proxy"
  },
  "sleeves": [
    {
      "sleeve_id": "main",
      "description": "Quality + Momentum + Low Vol 복합 팩터 (20종목 동일가중)",
      "node_graph": {
        "nodes": {
          "mom": {
            "node_id": "mom",
            "type": "field",
            "field_id": "ret_60d",
            "lag": 0,
            "null_policy": "drop"
          },
          "qual": {
            "node_id": "qual",
            "type": "field",
            "field_id": "op_income_growth_yoy",
            "lag": 0,
            "null_policy": "drop"
          },
          "vol": {
            "node_id": "vol",
            "type": "field",
            "field_id": "vol_20d",
            "lag": 0,
            "null_policy": "drop"
          },
          "mom_z": {
            "node_id": "mom_z",
            "type": "cs_op",
            "op": "zscore",
            "input": "mom",
            "null_policy": "drop"
          },
          "qual_z": {
            "node_id": "qual_z",
            "type": "cs_op",
            "op": "zscore",
            "input": "qual",
            "null_policy": "drop"
          },
          "vol_z": {
            "node_id": "vol_z",
            "type": "cs_op",
            "op": "zscore",
            "input": "vol",
            "null_policy": "drop"
          },
          "vol_neg": {
            "node_id": "vol_neg",
            "type": "cs_op",
            "op": "neg",
            "input": "vol_z",
            "null_policy": "drop"
          },
          "score": {
            "node_id": "score",
            "type": "combine",
            "op": "weighted_sum",
            "inputs": ["qual_z", "mom_z", "vol_neg"],
            "params": {"weights": [0.333, 0.333, 0.334]},
            "null_policy": "drop"
          }
        },
        "output": "score"
      },
      "selection": {
        "method": "top_n",
        "n": 20,
        "min_names": 10
      },
      "allocator": {
        "type": "equal_weight"
      },
      "constraints": {
        "long_only": true,
        "fully_invested": true,
        "max_weight": 0.15,
        "min_weight": 0.0,
        "min_names": 10,
        "target_cash_weight": 0.005
      }
    }
  ],
  "portfolio_aggregation": {
    "method": "fixed_mix",
    "sleeve_weights": {"main": 1.0},
    "normalize": true
  },
  "rebalancing": {
    "frequency": "monthly",
    "day_of_month": 1,
    "look_ahead_buffer": 1,
    "execution_cadence": "weekly",
    "min_turnover_per_rebalance": 0.05,
    "max_turnover_per_rebalance": 0.15
  },
  "execution": {
    "fill_rule": "next_open",
    "commission_bps": 10.0,
    "sell_tax_bps": 20.0,
    "slippage_bps": 10.0,
    "initial_capital": 1000000000,
    "round_lot": 1
  },
  "reporting": {
    "charts": ["nav", "drawdown", "turnover", "sector_exposure"],
    "tables": ["summary_metrics", "monthly_returns", "top_holdings", "top_trades", "constraint_violations"]
  },
  "tags": ["contest", "gradual-execution", "dual-cadence", "multifactor", "low-vol"]
}
