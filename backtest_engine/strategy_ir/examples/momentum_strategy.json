{
  "version": "1.0",
  "strategy_id": "momentum_12_1",
  "strategy_name": "12-Month Momentum (Skip 1M)",
  "mode": "research",
  "description": "Buy the top 20 stocks by 3-month momentum, skipping the most recent month. Equal-weighted, monthly rebalancing.",
  "objective": "maximize_return",
  "date_range": {
    "start": "2022-01-01",
    "end": "2025-12-31"
  },
  "base_universe": {
    "base": "is_eligible",
    "markets": ["코스피", "코스닥"],
    "include_blocked": false
  },
  "benchmark": {
    "index_code": "KOSPI200",
    "proxy_type": "return_proxy"
  },
  "sleeves": [
    {
      "sleeve_id": "main",
      "description": "Cross-sectional momentum sleeve",
      "node_graph": {
        "nodes": {
          "raw_momentum": {
            "node_id": "raw_momentum",
            "type": "field",
            "field_id": "ret_60d",
            "lag": 20,
            "null_policy": "drop"
          },
          "recent_ret": {
            "node_id": "recent_ret",
            "type": "field",
            "field_id": "ret_20d",
            "lag": 0,
            "null_policy": "drop"
          },
          "skip_ret": {
            "node_id": "skip_ret",
            "type": "combine",
            "op": "sub",
            "inputs": ["raw_momentum", "recent_ret"],
            "null_policy": "drop"
          },
          "winsorized": {
            "node_id": "winsorized",
            "type": "cs_op",
            "op": "winsorize",
            "input": "skip_ret",
            "params": {"lower": 0.01, "upper": 0.99},
            "null_policy": "drop"
          },
          "score": {
            "node_id": "score",
            "type": "cs_op",
            "op": "rank",
            "input": "winsorized",
            "null_policy": "drop"
          }
        },
        "output": "score"
      },
      "score_ref": "score",
      "selection": {
        "method": "top_n",
        "n": 20,
        "min_names": 10
      },
      "allocator": {
        "type": "equal_weight"
      },
      "constraints": {
        "long_only": true,
        "fully_invested": true,
        "max_weight": 0.15,
        "min_weight": 0.0,
        "min_names": 10,
        "target_cash_weight": 0.005
      }
    }
  ],
  "portfolio_aggregation": {
    "method": "fixed_mix",
    "sleeve_weights": {"main": 1.0},
    "normalize": true,
    "final_constraints": {
      "long_only": true,
      "max_weight": 0.15,
      "min_names": 10,
      "target_cash_weight": 0.005
    },
    "global_node_graph": {"nodes": {}, "output": null}
  },
  "rebalancing": {
    "frequency": "monthly",
    "day_of_month": 1,
    "look_ahead_buffer": 1
  },
  "execution": {
    "fill_rule": "next_open",
    "commission_bps": 10.0,
    "sell_tax_bps": 20.0,
    "slippage_bps": 10.0,
    "initial_capital": 1000000000,
    "round_lot": 1
  },
  "reporting": {
    "charts": ["nav", "drawdown", "turnover", "sector_exposure"],
    "tables": ["summary_metrics", "monthly_returns", "top_holdings", "top_trades"],
    "top_n_holdings": 20,
    "top_n_trades": 20,
    "annualization_factor": 252
  },
  "tags": ["momentum", "cross-sectional", "long-only"]
}
