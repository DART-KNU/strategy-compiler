{
  "version": "1.0",
  "strategy_id": "enhanced_kospi200",
  "strategy_name": "Enhanced KOSPI200 Index",
  "mode": "research",
  "description": "Tracks KOSPI200 with a momentum alpha tilt. Minimizes tracking error while adding positive momentum alpha. Uses enhanced_index allocator with low TE target.",
  "objective": "enhanced_index",
  "date_range": {
    "start": "2022-01-01",
    "end": "2025-12-31"
  },
  "base_universe": {
    "base": "is_eligible",
    "markets": ["코스피", "코스닥"],
    "include_blocked": false
  },
  "benchmark": {
    "index_code": "KOSPI200",
    "proxy_type": "enhanced_index"
  },
  "sleeves": [
    {
      "sleeve_id": "enhanced",
      "description": "Enhanced index sleeve with momentum alpha",
      "node_graph": {
        "nodes": {
          "momentum": {
            "node_id": "momentum",
            "type": "field",
            "field_id": "ret_60d",
            "lag": 0,
            "null_policy": "drop"
          },
          "low_vol_flag": {
            "node_id": "low_vol_flag",
            "type": "field",
            "field_id": "vol_20d",
            "lag": 0,
            "null_policy": "drop"
          },
          "alpha_signal": {
            "node_id": "alpha_signal",
            "type": "cs_op",
            "op": "zscore",
            "input": "momentum",
            "null_policy": "drop"
          }
        },
        "output": "alpha_signal"
      },
      "score_ref": "alpha_signal",
      "selection": {
        "method": "optimizer_only",
        "min_names": 30
      },
      "allocator": {
        "type": "enhanced_index",
        "benchmark_index": "KOSPI200",
        "alpha_ref": "alpha_signal",
        "alpha_weight": 1.0,
        "te_penalty": 5.0,
        "turnover_penalty": 0.002,
        "te_target": 0.05,
        "cov_model": "shrinkage_cov"
      },
      "constraints": {
        "long_only": true,
        "fully_invested": true,
        "max_weight": 0.15,
        "min_weight": 0.0,
        "min_names": 30,
        "target_cash_weight": 0.005
      }
    }
  ],
  "portfolio_aggregation": {
    "method": "fixed_mix",
    "sleeve_weights": {"enhanced": 1.0},
    "normalize": true,
    "final_constraints": {
      "long_only": true,
      "max_weight": 0.15,
      "min_names": 30,
      "target_cash_weight": 0.005
    },
    "global_node_graph": {"nodes": {}, "output": null}
  },
  "rebalancing": {
    "frequency": "monthly",
    "day_of_month": 1,
    "look_ahead_buffer": 1
  },
  "execution": {
    "fill_rule": "next_open",
    "commission_bps": 10.0,
    "sell_tax_bps": 20.0,
    "slippage_bps": 10.0,
    "initial_capital": 1000000000,
    "round_lot": 1
  },
  "reporting": {
    "charts": ["nav", "drawdown", "turnover", "sector_exposure"],
    "tables": ["summary_metrics", "monthly_returns", "top_holdings"],
    "top_n_holdings": 30,
    "top_n_trades": 20,
    "annualization_factor": 252
  },
  "tags": ["enhanced_index", "benchmark_tracking", "momentum_alpha", "KOSPI200"]
}
