    "mode": {
      "$ref": "#/$defs/RunMode",
      "default": "research"
    },
    "description": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Description"
    },
    "objective": {
      "default": "maximize_return",
      "description": "Human-readable objective: maximize_return / minimize_te / enhanced_index / etc.",
      "title": "Objective",
      "type": "string"
    },
    "date_range": {
      "$ref": "#/$defs/DateRange"
    },
    "base_universe": {
      "$ref": "#/$defs/UniverseConfig"
    },
    "benchmark": {
